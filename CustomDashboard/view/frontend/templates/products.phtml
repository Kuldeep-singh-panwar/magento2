<!-- Popup Modal -->
<div id="productModal" class="modal">
    <div class="modal-content">
        <span onclick="closeModal()" class="close-modal">&times;</span>
        <div id="modalContent" class="modal-body">
            <div class="loading-spinner"></div>
        </div>
    </div>
</div>

<script>
var mediaUrl = "<?= $block->getBaseUrl() .'pub/media/' ?>";
var image = mediaUrl + "custom/ai_ads.png";
function showProduct(productId) {
    // Show modal
    document.getElementById('productModal').style.display = 'block';
    document.getElementById('modalContent').innerHTML = '<div class="loading-spinner"></div>';
    
    // Get product details via AJAX
    fetch('<?= $block->getUrl('dashboard/index/getproduct') ?>?id=' + productId)
        .then(response => {
            if (!response.ok) {
                throw new Error('Network response was not ok');
            }
            return response.json();
        })
        .then(data => {
            if (data.error) {
                throw new Error(data.error);
            }
            
            // Update the modal content with clickable images
            let html = `
                <div class="modal-feature-images" style="text-align: center; display: flex; gap: 20px; justify-content: center; flex-wrap: wrap;">
                    <div class="modal-product-image" onclick="redirectToVideoGenerate(${productId}, 'ai_ads')" style="cursor: pointer;">
                        <img src="${image}" alt="ai_ads.png">
                        <h3 class="modal-product-title" style="margin-top: 10px;">AI Ads Videos</h3>
                    </div>
                    <div class="modal-product-image" onclick="redirectToVideoGenerate(${productId}, 'product_showcase')" style="cursor: pointer;">
                        <img src="${image}" alt="ai_ads.png">
                        <h3 class="modal-product-title" style="margin-top: 10px;">Product Showcase Videos</h3>
                    </div>
                    <div class="modal-product-image" onclick="redirectToVideoGenerate(${productId}, 'fashion')" style="cursor: pointer;">
                        <img src="${image}" alt="ai_ads.png">
                        <h3 class="modal-product-title" style="margin-top: 10px;">Fashion Videos</h3>
                    </div>
                </div>
            `;
            document.getElementById('modalContent').innerHTML = html;
        })
        .catch(error => {
            console.error('Error:', error);
            document.getElementById('modalContent').innerHTML = `
                <div class="error-state">
                    <p>Error loading product details. Please try again.</p>
                    <button onclick="closeModal()" class="btn-details" style="margin-top: 15px;">Close</button>
                </div>
            `;
        });
}

// New function to redirect to video generation page
function redirectToVideoGenerate(productId, videoType) {
    closeModal();
    window.location.href = '<?= $block->getUrl('dashboard/index/videogenerate') ?>?id=' + productId + '&type=' + videoType;
}

function closeModal() {
    document.getElementById('productModal').style.display = 'none';
}

// Close modal when clicking outside
window.onclick = function(event) {
    var modal = document.getElementById('productModal');
    if (event.target == modal) {
        closeModal();
    }
}
</script>