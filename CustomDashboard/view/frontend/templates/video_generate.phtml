<script>
require(['jquery'], function($) {
    // Tab switching functionality
    $(".tab").on("click", function() {
        $(".tab").removeClass("active");
        $(this).addClass("active");

        if ($(this).data("tab") === "auto") {
            $("#autoContent").show();
            $("#customContent").hide();
        } else {
            $("#autoContent").hide();
            $("#customContent").show();
        }
    });

    $('.productDuration').on('change', function () {
        var value = $(this).val();
        $('.productDuration[value="' + value + '"]').prop('checked', true);
    });

    $('.deleteProductImage').on('click', function () {      
        $('#product_image').attr('data-url', '');  
        $('.product_image').attr('src', '<?= $uploadPhImg;?>');  
        $('.product_image').attr('src', '<?= $uploadPhImg;?>');  
    });

    // Handle radio button styling
    $(".duration-group input[type='radio']").on("change", function() {
        $(this).closest(".duration-group").find("label").removeClass("checked");
        $(this).next("label").addClass("checked");
    });
});

// Image upload preview
function readURL(input) {
    if (input.files && input.files[0]) {
        var reader = new FileReader();
        reader.onload = function(e) {
            jQuery('.product_image').attr('src', e.target.result);
            jQuery('#product_image').attr('data-url', e.target.result);
        };
        reader.readAsDataURL(input.files[0]);
    }
}

// Select sample image
function selectSampleImage(imgElement) {
    var imgSrc = jQuery(imgElement).attr('src');
    jQuery('.product_image').attr('src', imgSrc);
    jQuery('#product_image').attr('data-url', imgSrc);
    
    // Optionally trigger any additional events
    jQuery('#product_image').val(''); // Clear file input as we're using sample
}

// Generate script function
function generateScript() {
    var idea = jQuery('#custom_idea').val();
    var productName = jQuery('#product_name').val() || '';
    var productDescription = jQuery('#product_description').val() || '';
    var productSellingPoint = jQuery('#product_selling_point').val() || '';
    var productTargetAudience = jQuery('#product_target_audience').val() || 'Young Adults';
    var productAdStyle = jQuery('#product_ad_style').val() || 'UGC Ads';
    var productDuration = jQuery('input[name="productDuration"]:checked').val() || '10';
    var productImage = jQuery('#product_image').attr('data-url');
    
    if (!productImage) {
        alert('Product Image is required.');
        return;
    }
    
    jQuery('#generateScriptBtn').prop('disabled', true).text('Generating...');
    var videoType = (jQuery('.tab.active').text() == 'Auto' ? 'aiAdsSora2':'aiAds') // Default agar URL mein na ho
    
    // Make AJAX call with type in URL
    jQuery.ajax({
        url: '<?= $block->getUrl('dashboard/index/generateprompt') ?>',
        type: 'POST',
        data: {
            extraOptions: {
                idea: idea,
                productName: productName,
                productDescription: productDescription,
                productSellingPoint: productSellingPoint,
                productTargetAudience: productTargetAudience,
                productAdStyle: productAdStyle,
                productDuration: productDuration,
            },
            type: videoType,
            image: productImage
            // type yahan nahi bhejna because it's in URL
        },
        success: function(response) {            
            let resp = response.data;
            if (resp.status) {
                if(videoType == 'aiAdsSora2'){
                    jQuery('#scene_description').val(resp.data.script);
                }else{
                    var shots = resp.data.shots;
                    var html = '';
                    var text = '';
                    shots.forEach(function(shot, index){

                        text += "Shot " + (index + 1) + "\n";
                        text += "Duration: [" + shot.duration + "]\n";
                        text += "Visual Description: " + shot.visualDescription + "\n";
                        text += "Dialogue: \"" + shot.dialogue + "\"\n\n";

                    });
                    text += " Keep logo visible and don't destroy it\nDon't add overlay text\nNo text on screen";

                    jQuery('#scene_description').val(text);
                }
                jQuery('.tab[data-tab="auto"]').click(); // Switch to auto tab
                
                // Show success message
                if (jQuery('#successMessage').length) {
                    jQuery('#successMessage').show().text('Script generated successfully!').fadeOut(3000);
                }
            } else {
                if (jQuery('#errorMessage').length) {
                    jQuery('#errorMessage').show().text(resp.message || 'Failed to generate script');
                } else {
                    alert(resp.message || 'Failed to generate script');
                }
            }
        },
        error: function(xhr, status, error) {
            console.error('AJAX Error:', error);
            console.error('Response:', xhr.responseText);
            
            var errorMsg = 'Error connecting to server';
            if (xhr.responseJSON && xhr.responseJSON.message) {
                errorMsg = xhr.responseJSON.message;
            }
            
            if (jQuery('#errorMessage').length) {
                jQuery('#errorMessage').show().text(errorMsg);
            } else {
                alert(errorMsg);
            }
        },
        complete: function() {
            // Re-enable button
            jQuery('#generateScriptBtn').prop('disabled', false).text('Generate Script');
        }
    });
}

function generateVideo() {

    var formData = {
        image: jQuery('#product_image').attr('data-url'),
        title: jQuery('#video_title').val(),
        prompt: jQuery('#scene_description').val(),
        aspectRatio: jQuery('input[name="aspect_ratio"]:checked').val(),
        duration: jQuery('input[name="video_duration"]:checked').val()       
    };
    
    var productImage = jQuery('#product_image').attr('data-url');
    
    if (!productImage) {
        alert('Product Image is required.');
        return;
    }

    // Make AJAX call with type in URL
    jQuery.ajax({
        url: '<?= $block->getUrl('dashboard/index/Videogenerate') ?>',
        type: 'POST',
        data: formData,
        success: function(response) {            
            let resp = response.data;
            console.log(resp);
            
            if (resp.status) {
                // Show success message
                if (jQuery('#successMessage').length) {
                    jQuery('#successMessage').show().text('Script generated successfully!').fadeOut(3000);
                }
            } else {
                if (jQuery('#errorMessage').length) {
                    jQuery('#errorMessage').show().text(resp.message || 'Failed to generate script');
                } else {
                    alert(resp.message || 'Failed to generate script');
                }
            }
        },
        error: function(xhr, status, error) {
            console.error('AJAX Error:', error);
            console.error('Response:', xhr.responseText);
            
            var errorMsg = 'Error connecting to server';
            if (xhr.responseJSON && xhr.responseJSON.message) {
                errorMsg = xhr.responseJSON.message;
            }
            
            if (jQuery('#errorMessage').length) {
                jQuery('#errorMessage').show().text(errorMsg);
            } else {
                alert(errorMsg);
            }
        },
        complete: function() {
            // Re-enable button
            jQuery('#generateScriptBtn').prop('disabled', false).text('Generate Script');
        }
    });
}


</script>