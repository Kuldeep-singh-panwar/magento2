<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
      layout="2columns-left" 
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <css src="Testing_CustomDashboard::css/dashboard.css"/>
    </head>
    <body>
        <referenceContainer name="sidebar.main">
            <block class="Testing\CustomDashboard\Block\Dashboard" 
                   name="dashboard.sidebar" 
                   template="Testing_CustomDashboard::dashboard.phtml"/>
        </referenceContainer>
        <referenceContainer name="content">
            <block class="Testing\CustomDashboard\Block\Dashboard" 
                   name="dashboard.content.info" 
                   template="Testing_CustomDashboard::info.phtml"/>
        </referenceContainer>
    </body>
</page>